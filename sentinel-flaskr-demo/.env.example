# Copy this file to .env and fill in your values.
# The app runs without Make webhook URLs — calls are silently skipped if not set.

# Flask
SECRET_KEY=dev-change-this-in-production

# Stage 1: Blog post → Make → Slack + LinkedIn
# Get this URL from your Make scenario's Custom Webhook trigger module
MAKE_WEBHOOK_BLOG_POST=

# Stage 2: Lead capture → Make → HubSpot + email
MAKE_WEBHOOK_LEAD_CAPTURE=

# Stage 3: Case study request → Make → approval workflow
MAKE_WEBHOOK_CASE_STUDY_REQUEST=

# Email address that receives case study approval requests (used in Make scenario config)
SENTINEL_REVIEW_EMAIL=
